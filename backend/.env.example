# ==========================================
# Server Configuration
# ==========================================
PORT=5001
NODE_ENV=development
TZ=America/New_York

# ==========================================
# Database & Cache (Docker Local Defaults)
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@db:5432/sme_sync
REDIS_URL=redis://redis:6379

# ==========================================
# QuickBooks Online API
# ==========================================
QB_CLIENT_ID=your_quickbooks_client_id
QB_CLIENT_SECRET=your_quickbooks_client_secret
QB_REDIRECT_URI=http://localhost:5001/api/auth/quickbooks/callback
QB_ENVIRONMENT=sandbox # sandbox or production
QB_VERIFIER_TOKEN=your_quickbooks_webhook_verifier_token

# ==========================================
# Gmail Integration (SMTP)
# ==========================================
GMAIL_USER=your_company_email@gmail.com
# 16-character App Password generated under Google Account -> Security -> 2-Step Verification
GMAIL_APP_PASS="xxxx xxxx xxxx xxxx"

# ==========================================
# Google Sheets (Apps Script Web App)
# ==========================================
GOOGLE_SHEETS_WEB_APP_URL=https://script.google.com/macros/s/xxxx/exec
